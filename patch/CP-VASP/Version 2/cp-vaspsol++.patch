       END SUBROUTINE ELECTRONIC_OPTIMIZATION
 
+!cpm
+      SUBROUTINE NHC_STEP(Vne, Mne, M, M_eta, T_eta, delta_t, Glogs, Vlogs, Xlogs)
+        REAL(q) Vne, Mne, M_eta, T_eta, delta_t, rescale, wdt, KE, KE2, tmp, AA
+        INTEGER M, I, J
+        REAL(q) Glogs(M), Vlogs(M), Xlogs(M), Q(M)
+        REAL    wdti(3)
+
+        rescale = 1.0
+        KE = 0.5 * Mne * Vne**2
+        KE2 = KE * 2
+        Q = M_eta
+        tmp = 1 / (2 - 2**(1./3))
+        wdti = tmp * delta_t
+        wdti(2) = (1 - 2 * tmp) * delta_t
+        Glogs(1) = (KE2 - BOLKEV * T_eta) / Q(1)
+
+        DO I=1,3
+          wdt = wdti(I)
+          Vlogs(M) = Vlogs(M) + 0.25 * Glogs(M) * wdt
+          DO J=1,M-1
+            AA = exp(-0.125 * wdt * Vlogs(M-J+1))
+            Vlogs(M-J) = Vlogs(M-J) * AA**2 + 0.25 * wdt * Glogs(M-J) * AA
+          END DO
+          AA = exp(-0.5 * wdt * Vlogs(1))
+          rescale = rescale * AA
+          Glogs(1) = (rescale**2 * KE2 - BOLKEV * T_eta) / Q(1)
+          Xlogs = Xlogs + 0.5 * Vlogs * wdt
+          DO J=1,M-1
+            AA = exp(-0.125 * wdt * Vlogs(J+1))
+            Vlogs(J) = Vlogs(J) * AA**2 + 0.25 * wdt * Glogs(J) * AA
+            Glogs(J+1) = (Q(J) * Vlogs(J)**2 - BOLKEV * T_eta) / Q(J+1)
+          END DO
+          Vlogs(M) = Vlogs(M) + 0.25 * Glogs(M) * wdt
+          WRITE(TIU0, *) "I = ", I, " rescale = ", rescale
+        END DO
+        Vne = Vne * rescale
+
+      END SUBROUTINE NHC_STEP
+
